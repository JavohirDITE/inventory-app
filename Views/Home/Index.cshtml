@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">Hello World!</h1>
    <p class="lead">Welcome to the Inventory Management App</p>

    <div class="mt-4">
        @if (ViewBag.DbConnected == true)
        {
            <div class="alert alert-success" role="alert">
                <i class="bi bi-check-circle-fill"></i> Successfully connected to PostgreSQL Database!
            </div>
        }
        else
        {
            <div class="alert alert-danger" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> Failed to connect to the database. Check the configuration.
            </div>
        }
    </div>
</div>
