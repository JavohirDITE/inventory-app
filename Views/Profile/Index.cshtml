@model InventoryApp.Controllers.ProfileViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["My Profile"];
}

<div class="container my-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="mb-0">
                <i class="bi bi-person-circle"></i> @User.Identity?.Name
            </h2>
            <p class="text-muted mb-0">@Localizer["Manage your inventories and shared content."]</p>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-secondary" asp-area="Identity" asp-page="/Account/Manage/Index">
                <i class="bi bi-gear"></i> @Localizer["Account Settings"]
            </a>
            <a class="btn btn-primary" asp-controller="Inventories" asp-action="Create">
                <i class="bi bi-plus-lg"></i> @Localizer["Create Inventory"]
            </a>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" id="profileTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="owned-tab" data-bs-toggle="tab" data-bs-target="#owned" type="button" role="tab" aria-controls="owned" aria-selected="true">
                <i class="bi bi-collection-fill"></i> @Localizer["My Inventories"]
                <span class="badge bg-secondary rounded-pill ms-1">@Model.MyInventories.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="shared-tab" data-bs-toggle="tab" data-bs-target="#shared" type="button" role="tab" aria-controls="shared" aria-selected="false">
                <i class="bi bi-share-fill"></i> @Localizer["Shared With Me"]
                <span class="badge bg-secondary rounded-pill ms-1">@Model.SharedInventories.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="profileTabsContent">
        <!-- MY INVENTORIES -->
        <div class="tab-pane fade show active" id="owned" role="tabpanel" aria-labelledby="owned-tab">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    @if (Model.MyInventories.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>@Localizer["Title"]</th>
                                        <th>@Localizer["Category"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var inv in Model.MyInventories)
                                    {
                                        <tr>
                                            <td class="fw-bold">
                                                <a asp-controller="Inventories" asp-action="Details" asp-route-id="@inv.Id" class="text-decoration-none text-reset">
                                                    @inv.Title
                                                </a>
                                            </td>
                                            <td><span class="badge bg-primary">@inv.Category?.Name</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            <p>@Localizer["You haven't created any inventories yet."]</p>
                            <a class="btn btn-primary mt-2" asp-controller="Inventories" asp-action="Create">@Localizer["Create First Inventory"]</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- SHARED WITH ME -->
        <div class="tab-pane fade" id="shared" role="tabpanel" aria-labelledby="shared-tab">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    @if (Model.SharedInventories.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>@Localizer["Title"]</th>
                                        <th>@Localizer["Category"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var inv in Model.SharedInventories)
                                    {
                                        <tr>
                                            <td class="fw-bold">
                                                <a asp-controller="Inventories" asp-action="Details" asp-route-id="@inv.Id" class="text-decoration-none text-reset">
                                                    @inv.Title
                                                </a>
                                            </td>
                                            <td><span class="badge bg-primary">@inv.Category?.Name</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-share fs-1 d-block mb-3"></i>
                            <p>@Localizer["No inventories have been shared with you yet."]</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
