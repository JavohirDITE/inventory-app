@model InventoryApp.Models.ViewModels.TicketViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Support Ticket"];
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-life-preserver me-2"></i>@Localizer["Create Support Ticket"]</h4>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <div asp-validation-summary="All" class="text-danger mb-0"></div>
                    </div>
                }

                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="PageLink" />
                    <input type="hidden" asp-for="InventoryTitle" />

                    @if (!string.IsNullOrEmpty(Model.InventoryTitle))
                    {
                        <div class="alert alert-info py-2">
                            <small class="mb-0"><strong>@Localizer["Related to:"]</strong> @Model.InventoryTitle</small>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Summary" class="form-label fw-bold">@Localizer["Problem Summary"]</label>
                        <textarea asp-for="Summary" class="form-control" rows="4" placeholder="@Localizer["Describe the issue you are facing..."]" required></textarea>
                        <span asp-validation-for="Summary" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Priority" class="form-label fw-bold">@Localizer["Priority"]</label>
                        <select asp-for="Priority" class="form-select">
                            <option value="High">@Localizer["High"]</option>
                            <option value="Average" selected>@Localizer["Average"]</option>
                            <option value="Low">@Localizer["Low"]</option>
                        </select>
                        <span asp-validation-for="Priority" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send me-1"></i> @Localizer["Submit Ticket"]
                        </button>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
            <div class="card-footer border-top-0 text-muted small text-center">
                <i class="bi bi-lightning-charge me-1"></i>@Localizer["This will automatically send a notification to our support team via Power Automate."]
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
