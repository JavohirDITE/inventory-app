@model InventoryApp.Models.Inventory
@{
    ViewData["Title"] = Localizer["Create Inventory"];
}

<h2>@Localizer["Create New Inventory"]</h2>
<hr />

<form asp-action="Create" method="post">
    <!-- Base Configuration -->
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Title" class="form-label fw-bold">@Localizer["Title"] *</label>
            <input asp-for="Title" class="form-control" required />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        
        <div class="col-md-6 mb-3">
            <label asp-for="CategoryId" class="form-label fw-bold">@Localizer["Category"] *</label>
            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId" required></select>
        </div>
    </div>
    
    <div class="mb-3">
        <label asp-for="Description" class="form-label fw-bold">@Localizer["Description"]</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>
    
    <div class="mb-3">
        <label asp-for="ImageUrl" class="form-label fw-bold">@Localizer["Image URL (Cloudinary integration in future)"]</label>
        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
    </div>
    
    <div class="form-check mb-4">
        <input asp-for="IsPublic" class="form-check-input" />
        <label class="form-check-label fw-bold" asp-for="IsPublic">
            @Localizer["Is Public (Allow any authenticated user to write items inside this inventory)"]
        </label>
    </div>

    <!-- Custom Fields Setup using simple accordion -->
    <div class="accordion mb-4" id="customFieldsAccordion">
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCustom" aria-expanded="false" aria-controls="collapseCustom">
            <strong>@Localizer["Setup Custom Item Fields"]</strong>
          </button>
        </h2>
        <div id="collapseCustom" class="accordion-collapse collapse" data-bs-parent="#customFieldsAccordion">
          <div class="accordion-body">
              <p class="text-muted">@Localizer["Check the box to enable a custom field slot, and provide a name for it."]</p>
              
              <div class="row">
                  <!-- Strings -->
                  <div class="col-md-4 mb-3 border-end">
                      <h5 class="mb-3">@Localizer["String Fields"] (x3)</h5>
                      @for(int i=1; i<=3; i++) {
                         <div class="input-group mb-2 input-group-sm">
                          <div class="input-group-text">
                            <input class="form-check-input mt-0" type="checkbox" name="CustomString@(i)State" value="true">
                          </div>
                          <input type="text" class="form-control" name="CustomString@(i)Name" placeholder="@Localizer["Field Name"]">
                        </div>
                      }
                  </div>
                  
                  <!-- Texts -->
                  <div class="col-md-4 mb-3 border-end">
                      <h5 class="mb-3">@Localizer["Text Fields"] (x3)</h5>
                      @for(int i=1; i<=3; i++) {
                         <div class="input-group mb-2 input-group-sm">
                          <div class="input-group-text">
                            <input class="form-check-input mt-0" type="checkbox" name="CustomText@(i)State" value="true">
                          </div>
                          <input type="text" class="form-control" name="CustomText@(i)Name" placeholder="@Localizer["Field Name"]">
                        </div>
                      }
                  </div>

                  <!-- Ints -->
                  <div class="col-md-4 mb-3">
                      <h5 class="mb-3">@Localizer["Integer Fields"] (x3)</h5>
                      @for(int i=1; i<=3; i++) {
                         <div class="input-group mb-2 input-group-sm">
                          <div class="input-group-text">
                            <input class="form-check-input mt-0" type="checkbox" name="CustomInt@(i)State" value="true">
                          </div>
                          <input type="text" class="form-control" name="CustomInt@(i)Name" placeholder="@Localizer["Field Name"]">
                        </div>
                      }
                  </div>
              </div>
              
              <hr />

              <div class="row">
                   <!-- Bools -->
                  <div class="col-md-4 mb-3 border-end">
                      <h5 class="mb-3">@Localizer["Boolean Fields"] (x3)</h5>
                      @for(int i=1; i<=3; i++) {
                         <div class="input-group mb-2 input-group-sm">
                          <div class="input-group-text">
                            <input class="form-check-input mt-0" type="checkbox" name="CustomBool@(i)State" value="true">
                          </div>
                          <input type="text" class="form-control" name="CustomBool@(i)Name" placeholder="@Localizer["Field Name"]">
                        </div>
                      }
                  </div>

                   <!-- Links -->
                  <div class="col-md-4 mb-3">
                      <h5 class="mb-3">@Localizer["Link Fields"] (x3)</h5>
                      @for(int i=1; i<=3; i++) {
                         <div class="input-group mb-2 input-group-sm">
                          <div class="input-group-text">
                            <input class="form-check-input mt-0" type="checkbox" name="CustomLink@(i)State" value="true">
                          </div>
                          <input type="text" class="form-control" name="CustomLink@(i)Name" placeholder="@Localizer["Field Name"]">
                        </div>
                      }
                  </div>
              </div>

          </div>
        </div>
      </div>
    </div>

    <div class="form-group mb-3">
        <button type="submit" class="btn btn-primary">@Localizer["Create"]</button>
        <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
