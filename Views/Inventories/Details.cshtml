@model InventoryApp.Models.ViewModels.InventoryDetailsViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = Model.Inventory.Title;
    var currentUserId = UserManager.GetUserId(User);
}

<!-- Flash Messages for Errors -->
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger mb-3">
        @TempData["ErrorMessage"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-3">
    <h2>@Model.Inventory.Title 
       <span class="badge bg-secondary fs-6 align-middle">@Model.Inventory.Category?.Name</span>
       @if (Model.Inventory.IsPublic) { <span class="badge bg-success fs-6 align-middle"><i class="bi bi-unlock"></i> @Localizer["Public Write"]</span> }
    </h2>
    
    @if (Model.IsOwnerOrAdmin)
    {
        <div>
            <a asp-action="Delete" asp-route-id="@Model.Inventory.Id" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash"></i> @Localizer["Delete Inventory"]
            </a>
        </div>
    }
</div>

<p class="text-muted mb-4">
    <i class="bi bi-person"></i> @Localizer["Created by"]: @Model.Inventory.Creator?.UserName
</p>

<!-- TABS NAVIGATION -->
<ul class="nav nav-tabs mb-4" id="inventoryTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link @(Model.ActiveTab == "items" ? "active" : "")" id="items-tab" data-bs-toggle="tab" data-bs-target="#items" type="button" role="tab" aria-controls="items" aria-selected="@(Model.ActiveTab == "items" ? "true" : "false")">
        <i class="bi bi-list-task"></i> @Localizer["Items"]
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link @(Model.ActiveTab == "discussion" ? "active" : "")" id="discussion-tab" data-bs-toggle="tab" data-bs-target="#discussion" type="button" role="tab" aria-controls="discussion" aria-selected="@(Model.ActiveTab == "discussion" ? "true" : "false")">
        <i class="bi bi-chat-dots"></i> @Localizer["Discussion"]
    </button>
  </li>
  
  @if (Model.IsOwnerOrAdmin)
  {
      <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.ActiveTab == "settings" ? "active" : "")" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab" aria-controls="settings" aria-selected="@(Model.ActiveTab == "settings" ? "true" : "false")">
             <i class="bi bi-gear"></i> @Localizer["Settings"]
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.ActiveTab == "access" ? "active" : "")" id="access-tab" data-bs-toggle="tab" data-bs-target="#access" type="button" role="tab" aria-controls="access" aria-selected="@(Model.ActiveTab == "access" ? "true" : "false")">
             <i class="bi bi-shield-lock"></i> @Localizer["Access"]
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.ActiveTab == "fields" ? "active" : "")" id="fields-tab" data-bs-toggle="tab" data-bs-target="#fields" type="button" role="tab" aria-controls="fields" aria-selected="@(Model.ActiveTab == "fields" ? "true" : "false")">
             <i class="bi bi-ui-checks"></i> @Localizer["Fields"]
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.ActiveTab == "customid" ? "active" : "")" id="customid-tab" data-bs-toggle="tab" data-bs-target="#customid" type="button" role="tab" aria-controls="customid" aria-selected="@(Model.ActiveTab == "customid" ? "true" : "false")">
             <i class="bi bi-hash"></i> @Localizer["Custom ID"]
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.ActiveTab == "statistics" ? "active" : "")" id="statistics-tab" data-bs-toggle="tab" data-bs-target="#statistics" type="button" role="tab" aria-controls="statistics" aria-selected="@(Model.ActiveTab == "statistics" ? "true" : "false")">
             <i class="bi bi-graph-up"></i> @Localizer["Statistics"]
        </button>
      </li>
  }
</ul>

<!-- TABS CONTENT -->
<div class="tab-content" id="inventoryTabsContent">
  
  <!-- ===============================
       1. ITEMS TAB 
       =============================== -->
  <div class="tab-pane fade @(Model.ActiveTab == "items" ? "show active" : "")" id="items" role="tabpanel" aria-labelledby="items-tab">
      
      @if (Model.HasWriteAccess)
      {
          <div class="mb-3 d-flex align-items-center">
              <a asp-controller="Items" asp-action="Create" asp-route-inventoryId="@Model.Inventory.Id" class="btn btn-primary"><i class="bi bi-plus-lg"></i> @Localizer["Add Item"]</a>
              
              <button class="btn btn-outline-secondary ms-2" id="toolbarEditBtn" disabled><i class="bi bi-pencil"></i> @Localizer["Edit Selected"]</button>
              
              <form id="deleteItemsForm" asp-controller="Items" asp-action="DeleteSelected" method="post" class="d-inline ms-2">
                  <input type="hidden" name="inventoryId" value="@Model.Inventory.Id" />
                  <button type="submit" class="btn btn-outline-danger" id="toolbarDeleteBtn" disabled onclick="return confirm('@Localizer["Are you sure you want to delete selected items?"]');">
                      <i class="bi bi-trash"></i> @Localizer["Delete Selected"]
                  </button>
              </form>
          </div>
      }

      <div class="table-responsive">
          <table class="table table-hover align-middle border">
              <thead class="table-light">
                  <tr>
                      @if (Model.HasWriteAccess) { <th style="width: 40px;"><input class="form-check-input" type="checkbox" id="selectAllItems"></th> }
                      <th>ID</th>
                      <th>@Localizer["Item Data"]</th>
                      <th>@Localizer["Created"]</th>
                      <th style="width: 80px;" class="text-center"><i class="bi bi-heart-fill text-danger"></i></th>
                  </tr>
              </thead>
              <tbody>
                  @if (Model.Items != null && Model.Items.Any())
                  {
                      foreach (var item in Model.Items)
                      {
                          <tr>
                              @if (Model.HasWriteAccess) 
                              { 
                                  <td>
                                      <input class="form-check-input item-checkbox" type="checkbox" name="itemIds" value="@item.Id" form="deleteItemsForm">
                                  </td> 
                              }
                              <td><code>@item.CustomId</code></td>
                              <td>
                                  @{
                                      var summaryLines = new List<string>();
                                      foreach (var p in new[] { "String", "Int", "Text", "Bool" })
                                      {
                                          for (int i = 1; i <= 3; i++)
                                          {
                                              var state = Model.Inventory.GetType().GetProperty($"Custom{p}{i}State")?.GetValue(Model.Inventory) as bool? ?? false;
                                              if (state)
                                              {
                                                  var name = Model.Inventory.GetType().GetProperty($"Custom{p}{i}Name")?.GetValue(Model.Inventory)?.ToString();
                                                  var val = item.GetType().GetProperty($"{p}{i}")?.GetValue(item)?.ToString();
                                                  if (!string.IsNullOrWhiteSpace(val))
                                                  {
                                                      summaryLines.Add($"<span class='text-muted small'>{name}:</span> <strong>{val}</strong>");
                                                  }
                                              }
                                          }
                                      }
                                  }
                                  @if (summaryLines.Any())
                                  {
                                      <div style="max-width:300px; white-space: normal; line-height: 1.4;">
                                          @Html.Raw(string.Join(" <span class='text-muted mx-1'>|</span> ", summaryLines))
                                      </div>
                                  }
                                  else
                                  {
                                      <span class="text-muted fst-italic">@Localizer["Empty"]</span>
                                  }
                              </td>
                              <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                              <td class="text-center">
                                  <button class="btn btn-sm btn-outline-danger border-0 like-btn" data-item-id="@item.Id" title="@Localizer["Like"]">
                                      <i class="bi bi-heart heart-icon"></i> <span class="like-count">...</span>
                                  </button>
                              </td>
                          </tr>
                      }
                  }
                  else
                  {
                      <tr>
                          <td colspan="4" class="text-center text-muted py-4">
                              <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                              @Localizer["No items found."]
                          </td>
                      </tr>
                  }
              </tbody>
          </table>
      </div>
  </div>

  <!-- ===============================
       2. DISCUSSION TAB 
       =============================== -->
  <div class="tab-pane fade @(Model.ActiveTab == "discussion" ? "show active" : "")" id="discussion" role="tabpanel" aria-labelledby="discussion-tab">
      
      <!-- Comments Container -->
      <div id="commentsContainer" class="mb-4" style="max-height: 500px; overflow-y: auto;">
          <div class="text-center text-muted" id="commentsLoading">
              <div class="spinner-border spinner-border-sm" role="status"></div> Loading discussion...
          </div>
      </div>

      @if (User.Identity?.IsAuthenticated == true)
      {
          <form id="commentForm" class="mt-3 border-top pt-3">
              <div class="mb-2">
                  <label class="form-label fw-bold">@Localizer["Leave a comment (Markdown supported)"]</label>
                  <textarea id="commentContent" class="form-control" rows="3" placeholder="@Localizer["Write something nice..."]" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary" id="postCommentBtn">
                  <i class="bi bi-send"></i> @Localizer["Post Comment"]
              </button>
          </form>
      }
      else
      {
          <div class="alert alert-secondary mt-3">
              <i class="bi bi-info-circle"></i> @Localizer["Please log in to participate in the discussion."]
          </div>
      }
  </div>

  @if (Model.IsOwnerOrAdmin)
  {
      <!-- ===============================
           3. SETTINGS TAB (Owner Only)
           =============================== -->
      <div class="tab-pane fade @(Model.ActiveTab == "settings" ? "show active" : "")" id="settings" role="tabpanel" aria-labelledby="settings-tab">
          <div class="card border-0 shadow-sm">
              <div class="card-body">
                  <h5 class="card-title mb-4">@Localizer["General Settings"]</h5>
                  
                  <form asp-action="UpdateSettings" method="post">
                      <input type="hidden" asp-for="Inventory.Id" />
                      <input type="hidden" asp-for="Inventory.Version" />
                      
                      <div class="mb-3">
                          <label asp-for="Inventory.Title" class="form-label fw-bold">@Localizer["Title"] *</label>
                          <input asp-for="Inventory.Title" class="form-control" required />
                      </div>
                      
                      <div class="mb-3">
                          <label asp-for="Inventory.CategoryId" class="form-label fw-bold">@Localizer["Category"] *</label>
                          <select asp-for="Inventory.CategoryId" class="form-select" asp-items="Model.CategorySelectList" required></select>
                      </div>

                      <div class="mb-3">
                          <label asp-for="Inventory.Description" class="form-label fw-bold">@Localizer["Description"]</label>
                          <textarea asp-for="Inventory.Description" class="form-control" rows="4"></textarea>
                      </div>

                      <div class="mb-3">
                          <label asp-for="Inventory.ImageUrl" class="form-label fw-bold">@Localizer["Image URL"]</label>
                          <input asp-for="Inventory.ImageUrl" class="form-control" />
                      </div>

                      <div class="form-check mb-4">
                          <input asp-for="Inventory.IsPublic" class="form-check-input" />
                          <label class="form-check-label fw-bold" asp-for="Inventory.IsPublic">
                              @Localizer["Is Public (Allow any authenticated user to write items inside this inventory)"]
                          </label>
                      </div>

                      <button type="submit" class="btn btn-primary">@Localizer["Save Settings"]</button>
                  </form>
              </div>
          </div>
      </div>

      <!-- ===============================
           4. ACCESS TAB (Owner Only)
           =============================== -->
      <div class="tab-pane fade @(Model.ActiveTab == "access" ? "show active" : "")" id="access" role="tabpanel" aria-labelledby="access-tab">
          <div class="card border-0 shadow-sm">
              <div class="card-body">
                  <h5 class="card-title mb-4">@Localizer["Manage Write Access"]</h5>
                  
                  <div class="alert alert-info py-2">
                       <small>@Localizer["Note: If 'Is Public' is enabled in Settings, all authenticated users have write access anyway."]</small>
                  </div>

                  <form asp-action="GrantAccess" method="post" class="d-flex mb-4">
                      <input type="hidden" name="inventoryId" value="@Model.Inventory.Id" />
                      <input type="text" name="userEmailOrName" class="form-control me-2" list="usersDatalist" id="userSearchInput" placeholder="@Localizer["Enter username or email"]" autocomplete="off" required>
                      <datalist id="usersDatalist"></datalist>
                      <button type="submit" class="btn btn-primary">@Localizer["Grant Access"]</button>
                  </form>

                  <form asp-action="RevokeAccess" method="post" id="revokeAccessForm">
                      <input type="hidden" name="inventoryId" value="@Model.Inventory.Id" />
                      <div class="mb-3">
                          <button type="submit" class="btn btn-danger btn-sm" id="btnRevokeAccess" disabled
                                  onclick="return confirm('@Localizer["Remove selected users from access list?"]');">
                              <i class="bi bi-person-dash"></i> @Localizer["Remove Selected"]
                          </button>
                      </div>

                      <div class="table-responsive">
                          <table class="table table-bordered table-hover align-middle">
                              <thead class="table-light">
                                  <tr>
                                      <th style="width: 40px;">
                                          <input class="form-check-input" type="checkbox" id="selectAllAccess">
                                      </th>
                                      <th>@Localizer["Username"]</th>
                                      <th>@Localizer["Email"]</th>
                                  </tr>
                              </thead>
                              <tbody>
                                  @if (Model.Inventory.Accesses.Any())
                                  {
                                      foreach (var access in Model.Inventory.Accesses)
                                      {
                                          <tr>
                                              <td>
                                                  <input class="form-check-input access-checkbox" type="checkbox" name="userIds" value="@access.UserId">
                                              </td>
                                              <td class="fw-bold">@access.User?.UserName</td>
                                              <td class="text-muted">@access.User?.Email</td>
                                          </tr>
                                      }
                                  }
                                  else
                                  {
                                      <tr>
                                          <td colspan="3" class="text-center text-muted py-3">@Localizer["No explicit users added yet."]</td>
                                      </tr>
                                  }
                              </tbody>
                          </table>
                      </div>
                  </form>
              </div>
          </div>
      </div>

      <!-- ===============================
           5. FIELDS TAB (Owner Only)
           =============================== -->
      <div class="tab-pane fade @(Model.ActiveTab == "fields" ? "show active" : "")" id="fields" role="tabpanel" aria-labelledby="fields-tab">
           <div class="card border-0 shadow-sm">
              <div class="card-body">
                  <h5 class="card-title mb-4">@Localizer["Custom Item Fields Mapping"]</h5>
                  
                  <form asp-action="UpdateFields" asp-route-id="@Model.Inventory.Id" method="post">
                      <input type="hidden" name="Inventory.Id" value="@Model.Inventory.Id" />
                      <input type="hidden" name="Inventory.Version" value="@Model.Inventory.Version" />
                      
                      <div class="row">
                          <!-- Strings -->
                          <div class="col-md-6 mb-4">
                              <h6 class="fw-bold border-bottom pb-2">@Localizer["Strings (x3)"]</h6>
                              @for(int i=1; i<=3; i++) {
                                 var stateProp = "CustomString" + i + "State";
                                 var nameProp = "CustomString" + i + "Name";
                                 var isChecked = (bool)Model.Inventory.GetType().GetProperty(stateProp).GetValue(Model.Inventory);
                                 var val = Model.Inventory.GetType().GetProperty(nameProp).GetValue(Model.Inventory)?.ToString();
                                 <div class="input-group mb-2 input-group-sm">
                                  <div class="input-group-text"><input class="form-check-input mt-0" type="checkbox" name="Inventory.@stateProp" value="true" @(isChecked ? "checked" : "")></div>
                                  <input type="text" class="form-control" name="Inventory.@nameProp" value="@val" placeholder="Field Name">
                                </div>
                              }
                          </div>
                          
                          <!-- Texts -->
                          <div class="col-md-6 mb-4">
                              <h6 class="fw-bold border-bottom pb-2">@Localizer["Text Areas (x3)"]</h6>
                              @for(int i=1; i<=3; i++) {
                                 var stateProp = "CustomText" + i + "State";
                                 var nameProp = "CustomText" + i + "Name";
                                 var isChecked = (bool)Model.Inventory.GetType().GetProperty(stateProp).GetValue(Model.Inventory);
                                 var val = Model.Inventory.GetType().GetProperty(nameProp).GetValue(Model.Inventory)?.ToString();
                                 <div class="input-group mb-2 input-group-sm">
                                  <div class="input-group-text"><input class="form-check-input mt-0" type="checkbox" name="Inventory.@stateProp" value="true" @(isChecked ? "checked" : "")></div>
                                  <input type="text" class="form-control" name="Inventory.@nameProp" value="@val" placeholder="Field Name">
                                </div>
                              }
                          </div>
                          
                          <!-- Ints -->
                          <div class="col-md-6 mb-4">
                              <h6 class="fw-bold border-bottom pb-2">@Localizer["Integers (x3)"]</h6>
                              @for(int i=1; i<=3; i++) {
                                 var stateProp = "CustomInt" + i + "State";
                                 var nameProp = "CustomInt" + i + "Name";
                                 var isChecked = (bool)Model.Inventory.GetType().GetProperty(stateProp).GetValue(Model.Inventory);
                                 var val = Model.Inventory.GetType().GetProperty(nameProp).GetValue(Model.Inventory)?.ToString();
                                 <div class="input-group mb-2 input-group-sm">
                                  <div class="input-group-text"><input class="form-check-input mt-0" type="checkbox" name="Inventory.@stateProp" value="true" @(isChecked ? "checked" : "")></div>
                                  <input type="text" class="form-control" name="Inventory.@nameProp" value="@val" placeholder="Field Name">
                                </div>
                              }
                          </div>

                          <!-- Bools -->
                          <div class="col-md-6 mb-4">
                              <h6 class="fw-bold border-bottom pb-2">@Localizer["Booleans (x3)"]</h6>
                              @for(int i=1; i<=3; i++) {
                                 var stateProp = "CustomBool" + i + "State";
                                 var nameProp = "CustomBool" + i + "Name";
                                 var isChecked = (bool)Model.Inventory.GetType().GetProperty(stateProp).GetValue(Model.Inventory);
                                 var val = Model.Inventory.GetType().GetProperty(nameProp).GetValue(Model.Inventory)?.ToString();
                                 <div class="input-group mb-2 input-group-sm">
                                  <div class="input-group-text"><input class="form-check-input mt-0" type="checkbox" name="Inventory.@stateProp" value="true" @(isChecked ? "checked" : "")></div>
                                  <input type="text" class="form-control" name="Inventory.@nameProp" value="@val" placeholder="Field Name">
                                </div>
                              }
                          </div>

                           <!-- Links -->
                          <div class="col-md-6 mb-4">
                              <h6 class="fw-bold border-bottom pb-2">@Localizer["Links (x3)"]</h6>
                              @for(int i=1; i<=3; i++) {
                                 var stateProp = "CustomLink" + i + "State";
                                 var nameProp = "CustomLink" + i + "Name";
                                 var isChecked = (bool)Model.Inventory.GetType().GetProperty(stateProp).GetValue(Model.Inventory);
                                 var val = Model.Inventory.GetType().GetProperty(nameProp).GetValue(Model.Inventory)?.ToString();
                                 <div class="input-group mb-2 input-group-sm">
                                  <div class="input-group-text"><input class="form-check-input mt-0" type="checkbox" name="Inventory.@stateProp" value="true" @(isChecked ? "checked" : "")></div>
                                  <input type="text" class="form-control" name="Inventory.@nameProp" value="@val" placeholder="Field Name">
                                </div>
                              }
                          </div>
                      </div>

                      <button type="submit" class="btn btn-primary mt-3">@Localizer["Save Fields Mapping"]</button>
                  </form>
              </div>
          </div>
      </div>

      <!-- ===============================
           6. CUSTOM ID TAB (Owner Only)
           =============================== -->
      <div class="tab-pane fade @(Model.ActiveTab == "customid" ? "show active" : "")" id="customid" role="tabpanel" aria-labelledby="customid-tab">
           <div class="card border-0 shadow-sm mb-4">
              <div class="card-body">
                  <h5 class="card-title mb-4">@Localizer["Custom ID Format Builder"]</h5>
                  <p class="text-muted">@Localizer["Configure how Item IDs are generated. The ID is assembled by joining these parts in order. Leave blank to use fallback GUIDs."]</p>
                  
                  <form asp-action="UpdateCustomIdMapping" method="post">
                      <input type="hidden" name="id" value="@Model.Inventory.Id" />
                      <input type="hidden" name="defaultVersion" value="@Model.Inventory.Version" />
                      
                      <div class="table-responsive">
                          <table class="table align-middle">
                              <thead>
                                  <tr>
                                      <th style="width: 50px;">#</th>
                                      <th>@Localizer["Part Type"]</th>
                                      <th>@Localizer["Settings"] (Text / DateFormat / Padding)</th>
                                  </tr>
                              </thead>
                              <tbody>
                                  @{
                                      var existingParts = Model.Inventory.CustomIdParts?.OrderBy(p => p.Order).ToList() ?? new List<CustomIdPart>();
                                      // Render 5 slots for simplicity
                                      for (int i = 0; i < 5; i++)
                                      {
                                          var part = i < existingParts.Count ? existingParts[i] : new CustomIdPart();
                                          <tr>
                                              <td class="text-muted fw-bold">@(i + 1)</td>
                                              <td>
                                                  <select name="parts[@i].PartType" class="form-select part-type-select" data-index="@i">
                                                      <option value="">-- @Localizer["Empty Slot"] --</option>
                                                      <!option value="FixedText" @(part.PartType == "FixedText" ? "selected" : "")>Fixed Text</!option>
                                                      <!option value="RandomHex20" @(part.PartType == "RandomHex20" ? "selected" : "")>Random (5 hex chars)</!option>
                                                      <!option value="RandomHex32" @(part.PartType == "RandomHex32" ? "selected" : "")>Random (8 hex chars)</!option>
                                                      <!option value="RandomDigits6" @(part.PartType == "RandomDigits6" ? "selected" : "")>Random (6 digits)</!option>
                                                      <!option value="RandomDigits9" @(part.PartType == "RandomDigits9" ? "selected" : "")>Random (9 digits)</!option>
                                                      <!option value="Sequence" @(part.PartType == "Sequence" ? "selected" : "")>Sequence Counter</!option>
                                                      <!option value="DateTime" @(part.PartType == "DateTime" ? "selected" : "")>Date/Time</!option>
                                                      <!option value="Guid" @(part.PartType == "Guid" ? "selected" : "")>GUID (N)</!option>
                                                  </select>
                                              </td>
                                              <td>
                                                  <div class="input-group">
                                                      <input type="text" name="parts[@i].TextValue" value="@part.TextValue" class="form-control" placeholder="Fixed Text Value" />
                                                      <input type="text" name="parts[@i].DateFormat" value="@part.DateFormat" class="form-control" placeholder="DateFormat (e.g. yyyyMM)" />
                                                      <input type="number" name="parts[@i].Padding" value="@part.Padding" class="form-control" placeholder="Padding (e.g. 4)" />
                                                  </div>
                                              </td>
                                          </tr>
                                      }
                                  }
                              </tbody>
                          </table>
                      </div>

                      <button type="submit" class="btn btn-primary mt-3">@Localizer["Save ID Format"]</button>
                  </form>
                  
                  <div class="mt-4 p-3 bg-light rounded border">
                      <h6 class="fw-bold text-muted mb-2">@Localizer["Live Preview Example"]:</h6>
                      <code id="customIdPreview" class="fs-5 text-dark"></code>
                  </div>
              </div>
          </div>
      </div>

      <!-- ===============================
           7. STATISTICS TAB (Owner Only)
           =============================== -->
      <div class="tab-pane fade @(Model.ActiveTab == "statistics" ? "show active" : "")" id="statistics" role="tabpanel" aria-labelledby="statistics-tab">
           <div class="card border-0 shadow-sm">
              <div class="card-body">
                  <h5 class="card-title mb-4">@Localizer["Inventory Metrics"]</h5>
                  
                  @if (Model.Statistics != null)
                  {
                      <div class="row g-4 mb-5">
                          <!-- Total Items -->
                          <div class="col-md-4">
                              <div class="card bg-primary text-white h-100 border-0 shadow-sm">
                                  <div class="card-body text-center d-flex flex-column justify-content-center">
                                      <i class="bi bi-box-seam fs-1 mb-2"></i>
                                      <h2 class="display-5 fw-bold mb-0">@Model.Statistics.TotalItems</h2>
                                      <p class="mb-0 text-white-50">@Localizer["Total Items"]</p>
                                  </div>
                              </div>
                          </div>
                      </div>

                      @if (Model.Statistics.NumericStats.Any())
                      {
                          <h6 class="fw-bold mb-3 border-bottom pb-2 text-muted">@Localizer["Numeric Field Aggregates"]</h6>
                          <div class="row g-3 mb-5">
                              @foreach (var stat in Model.Statistics.NumericStats)
                              {
                                  <div class="col-md-4">
                                      <div class="card border h-100 bg-light">
                                          <div class="card-body">
                                              <h6 class="card-title text-primary"><i class="bi bi-123"></i> @stat.Key</h6>
                                              <div class="d-flex justify-content-between mb-1 mt-3">
                                                  <span class="text-muted small">@Localizer["Average"]:</span>
                                                  <span class="fw-bold fs-5">@stat.Value.Avg</span>
                                              </div>
                                              <div class="d-flex justify-content-between small">
                                                  <span class="text-muted">@Localizer["Range"]:</span>
                                                  <span>@stat.Value.Min – @stat.Value.Max</span>
                                              </div>
                                          </div>
                                      </div>
                                  </div>
                              }
                          </div>
                      }

                      @if (Model.Statistics.StringTopStats.Any())
                      {
                          <h6 class="fw-bold mb-3 border-bottom pb-2 text-muted">@Localizer["Most Frequent String Values"]</h6>
                          <div class="row g-3">
                              @foreach (var stat in Model.Statistics.StringTopStats)
                              {
                                  <div class="col-md-4">
                                      <div class="card border h-100">
                                          <div class="card-body">
                                              <h6 class="card-title text-success"><i class="bi bi-type-text"></i> @stat.Key</h6>
                                              <ul class="list-group list-group-flush mt-3 border-top-0">
                                                  @foreach(var item in stat.Value)
                                                  {
                                                      <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                                                          <span class="text-truncate me-2">@item.Value</span>
                                                          <span class="badge bg-secondary rounded-pill">@item.Count</span>
                                                      </li>
                                                  }
                                              </ul>
                                          </div>
                                      </div>
                                  </div>
                              }
                          </div>
                      }
                      
                      @if (!Model.Statistics.NumericStats.Any() && !Model.Statistics.StringTopStats.Any())
                      {
                          <div class="text-center text-muted py-4">
                              <i class="bi bi-info-circle fs-3 d-block mb-3"></i>
                              @Localizer["Enable custom numeric or string fields inside the Fields mapping tab to see advanced metrics here."]
                          </div>
                      }
                  }
                  else
                  {
                      <div class="text-center text-muted py-4">
                          <div class="spinner-border text-primary" role="status"></div>
                          <p class="mt-3">@Localizer["Loading statistics..."]</p>
                      </div>
                  }
              </div>
          </div>
      </div>
  }

</div>

<div class="mt-4 border-top pt-3">
    <a asp-action="Index" class="btn btn-link text-decoration-none"><i class="bi bi-arrow-left"></i> @Localizer["Back to List"]</a>
</div>

@section Scripts {
    <!-- SignalR, Marked.js, DOMPurify for Phase 7 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.0.6/purify.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            // --- 1. Items Checkbox & Toolbar Logic ---
            const selectAllCheckbox = document.getElementById("selectAllItems");
            const itemCheckboxes = document.querySelectorAll(".item-checkbox");
            const editBtn = document.getElementById("toolbarEditBtn");
            const deleteBtn = document.getElementById("toolbarDeleteBtn");

            function updateToolbar() {
                const checkedCheckboxes = document.querySelectorAll(".item-checkbox:checked");
                const count = checkedCheckboxes.length;
                
                if (editBtn) {
                    if (count === 1) {
                        editBtn.disabled = false;
                        const itemId = checkedCheckboxes[0].value;
                        editBtn.onclick = function() {
                            window.location.href = '/Items/Edit/' + itemId;
                        };
                    } else {
                        editBtn.disabled = true;
                        editBtn.onclick = null;
                    }
                }

                if (deleteBtn) {
                    deleteBtn.disabled = count === 0;
                }
            }

            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener("change", function () {
                    itemCheckboxes.forEach(cb => cb.checked = selectAllCheckbox.checked);
                    updateToolbar();
                });
            }

            itemCheckboxes.forEach(cb => {
                cb.addEventListener("change", function () {
                    if (!this.checked && selectAllCheckbox) selectAllCheckbox.checked = false;
                    updateToolbar();
                });
            });

            // --- 2. Live Preview logic for Custom ID Tab ---
            const previewEl = document.getElementById("customIdPreview");
            if (previewEl) {
                const updatePreview = () => {
                    let previewStr = "";
                    for(let i=0; i<5; i++) {
                        const typeSelect = document.querySelector(`select[name='parts[${i}].PartType']`);
                        if(!typeSelect || !typeSelect.value) continue;
                        
                        const textVal = document.querySelector(`input[name='parts[${i}].TextValue']`).value || "";
                        const dateFmt = document.querySelector(`input[name='parts[${i}].DateFormat']`).value || "yyyyMMdd";
                        const padVal = parseInt(document.querySelector(`input[name='parts[${i}].Padding']`).value || "1");

                        switch(typeSelect.value) {
                            case "FixedText": previewStr += textVal; break;
                            case "RandomHex20": previewStr += "A1B2C"; break;
                            case "RandomHex32": previewStr += "A1B2C3D4"; break;
                            case "RandomDigits6": previewStr += "123456"; break;
                            case "RandomDigits9": previewStr += "123456789"; break;
                            case "Sequence": previewStr += "1".padStart(Math.max(1, padVal), '0'); break;
                            case "Guid": previewStr += "1234567890ABCDEF1234567890ABCDEF"; break;
                            case "DateTime": 
                                const d = new Date();
                                if(dateFmt.includes('yyyy')) previewStr += d.getFullYear();
                                else if (dateFmt.includes('yy')) previewStr += d.getFullYear().toString().slice(-2);
                                else previewStr += "DATE";
                                break;
                        }
                    }
                    previewEl.innerText = previewStr || "GUID (Fallback)";
                };

                const idInputs = document.querySelectorAll("#customid select, #customid input");
                idInputs.forEach(input => {
                    input.addEventListener('change', updatePreview);
                    input.addEventListener('keyup', updatePreview);
                });
                updatePreview();
            }

            // --- 3. Item Likes ---
            const likeBtns = document.querySelectorAll(".like-btn");
            likeBtns.forEach(btn => {
                const itemId = btn.getAttribute("data-item-id");
                
                // Load initial count
                fetch(`/api/likes/count/${itemId}`)
                    .then(r => r.json())
                    .then(data => {
                        btn.querySelector(".like-count").innerText = data.count || "0";
                        if (data.liked) {
                            btn.classList.remove("btn-outline-danger");
                            btn.classList.add("btn-danger");
                            btn.querySelector(".heart-icon").classList.replace("bi-heart", "bi-heart-fill");
                        }
                    });

                // Check auth before toggling logic
                btn.addEventListener("click", function() {
                    fetch(`/api/likes/toggle/${itemId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    }).then(r => {
                        if(r.status === 401) { alert("Please log in to like items."); return; }
                        return r.json();
                    }).then(data => {
                        if(!data) return;
                        btn.querySelector(".like-count").innerText = data.count;
                        if(data.liked) {
                            btn.classList.remove("btn-outline-danger");
                            btn.classList.add("btn-danger");
                            btn.querySelector(".heart-icon").classList.replace("bi-heart", "bi-heart-fill");
                        } else {
                            btn.classList.remove("btn-danger");
                            btn.classList.add("btn-outline-danger");
                            btn.querySelector(".heart-icon").classList.replace("bi-heart-fill", "bi-heart");
                        }
                    }).catch(err => console.error("Error toggling like", err));
                });
            });

            // --- 3.5 Access Tab Logic ---
            const searchInput = document.getElementById("userSearchInput");
            const datalist = document.getElementById("usersDatalist");
            if (searchInput && datalist) {
                let timeoutId;
                searchInput.addEventListener("input", function() {
                    clearTimeout(timeoutId);
                    const q = this.value.trim();
                    if (q.length < 2) {
                        datalist.innerHTML = "";
                        return;
                    }
                    timeoutId = setTimeout(() => {
                        fetch(`/api/users/search?q=${encodeURIComponent(q)}`)
                            .then(r => r.json())
                            .then(data => {
                                datalist.innerHTML = "";
                                data.forEach(u => {
                                    const option = document.createElement("option");
                                    option.value = u.email;
                                    option.textContent = u.userName;
                                    datalist.appendChild(option);
                                });
                            });
                    }, 300);
                });
            }

            const selectAll = document.getElementById("selectAllAccess");
            const accessCheckboxes = document.querySelectorAll(".access-checkbox");
            const btnRevoke = document.getElementById("btnRevokeAccess");
            
            function updateRevokeBtn() {
                if(btnRevoke) {
                    btnRevoke.disabled = !document.querySelector(".access-checkbox:checked");
                }
            }

            if (selectAll) {
                selectAll.addEventListener("change", function() {
                    accessCheckboxes.forEach(cb => cb.checked = selectAll.checked);
                    updateRevokeBtn();
                });
            }

            accessCheckboxes.forEach(cb => {
                cb.addEventListener("change", function() {
                    if (!this.checked && selectAll) selectAll.checked = false;
                    updateRevokeBtn();
                });
            });

            // --- 4. Realtime Discussion (SignalR) ---
            const inventoryId = @Model.Inventory.Id;
            const commentsContainer = document.getElementById("commentsContainer");
            const commentForm = document.getElementById("commentForm");
            const commentContent = document.getElementById("commentContent");
            const loadingIndicator = document.getElementById("commentsLoading");

            // Define safe markdown render method
            function renderComment(comment) {
                const safeHtml = DOMPurify.sanitize(marked.parse(comment.content));
                const dateStr = new Date(comment.createdAt).toLocaleString();
                
                const div = document.createElement("div");
                div.className = "card mb-3 shadow-sm border-0";
                div.innerHTML = `
                    <div class="card-header bg-transparent py-2 px-3 border-0">
                        <small class="text-muted"><i class="bi bi-person"></i> <strong>${comment.userName}</strong> &bull; ${dateStr}</small>
                    </div>
                    <div class="card-body py-2 px-3">
                        ${safeHtml}
                    </div>
                `;
                return div;
            }

            // Load existing comments
            fetch(`/api/comments/${inventoryId}`)
                .then(r => r.json())
                .then(comments => {
                    if (loadingIndicator) loadingIndicator.remove();
                    if (comments.length === 0) {
                        commentsContainer.innerHTML = `<div class="text-muted text-center py-4" id="emptyComments"><i class="bi bi-chat-dots fs-1 d-block mb-3"></i> No comments yet. Be the first to start the discussion!</div>`;
                    } else {
                        comments.forEach(c => commentsContainer.appendChild(renderComment(c)));
                    }
                    commentsContainer.scrollTop = commentsContainer.scrollHeight;
                });

            // SignalR Connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/discussionHub")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveComment", function (comment) {
                const empty = document.getElementById("emptyComments");
                if (empty) empty.remove();
                
                commentsContainer.appendChild(renderComment(comment));
                commentsContainer.scrollTop = commentsContainer.scrollHeight;
            });

            connection.start().then(function () {
                connection.invoke("JoinGroup", inventoryId.toString()).catch(err => console.error(err));
            }).catch(function (err) {
                console.error("SignalR Connection Error: ", err.toString());
            });

            // Post new comment
            if (commentForm) {
                commentForm.addEventListener("submit", function(e) {
                    e.preventDefault();
                    const text = commentContent.value;
                    if(!text) return;

                    fetch(`/api/comments`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ inventoryId: inventoryId, content: text })
                    }).then(r => {
                        if(r.ok) {
                            commentContent.value = "";
                        } else if(r.status === 401) {
                            alert("Please log in to comment.");
                        } else {
                            alert("Failed to post comment.");
                        }
                    });
                });
            }
        });
    </script>
}
