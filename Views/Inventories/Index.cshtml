@model IEnumerable<InventoryApp.Models.Inventory>
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = Localizer["Inventories"];
    var currentUserId = UserManager.GetUserId(User);
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2>@Localizer["All Inventories"]</h2>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> @Localizer["Create New"]</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle border shadow-sm">
        <thead class="table-light">
            <tr>
                <th scope="col" style="width: 50px;"></th>
                <th scope="col">@Localizer["Title"]</th>
                <th scope="col">@Localizer["Category"]</th>
                <th scope="col">@Localizer["Creator"]</th>
                <th scope="col">@Localizer["Description"]</th>
                <th scope="col" class="text-end">@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="Inventory Image" class="rounded" style="width: 40px; height: 40px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-box-seam"></i>
                            </div>
                        }
                    </td>
                    <td class="fw-bold">@item.Title</td>
                    <td><span class="badge bg-info text-dark">@item.Category?.Name</span></td>
                    <td><small class="text-muted">@item.Creator?.UserName</small></td>
                    <td class="text-truncate" style="max-width: 250px;">
                        <span title="@item.Description">@item.Description</span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">@Localizer["Details"]</a>
                        @if (item.CreatorId == currentUserId || User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm ms-1"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm ms-1"><i class="bi bi-trash"></i></a>
                        }
                    </td>
                </tr>
            }
            @if(!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        @Localizer["No inventories found."]
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
