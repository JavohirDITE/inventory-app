@model IEnumerable<InventoryApp.Models.Inventory>
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = Localizer["Inventories"];
    var currentUserId = UserManager.GetUserId(User);
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2>@Localizer["All Inventories"]</h2>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> @Localizer["Create New"]</a>
    }
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" class="card-img-top" alt="Inventory Image" style="object-fit:cover; height:200px;">
                }
                else
                {
                    <div class="card-img-top bg-secondary text-white d-flex align-items-center justify-content-center" style="height:200px;">
                        <i class="bi bi-box-seam" style="font-size: 4rem;"></i>
                    </div>
                }
                <div class="card-body">
                    <h5 class="card-title">@item.Title</h5>
                    <div class="badge bg-info mb-2">@item.Category?.Name</div>
                    
                    <p class="card-text text-truncate">@item.Description</p>
                    <p class="card-text"><small class="text-muted">@Localizer["Creator"]: @item.Creator?.UserName</small></p>
                </div>
                <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">@Localizer["Details"]</a>
                    
                    @if (item.CreatorId == currentUserId || User.IsInRole("Admin"))
                    {
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
